# Normalize line endings to LF for all files
* text=auto

# Explicitly set line endings to LF
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
*.ipynb text eol=lf

# Binary files
*.db binary
*.pyc binary
*.pyo binary
*.pyd binary
*.zip binary
*.tar binary
*.gz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
